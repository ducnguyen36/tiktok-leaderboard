# ============================================
# Helios Leaderboard — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://admin:YOUR_PASSWORD@cluster0.esecu0j.mongodb.net/?appName=Cluster0

# Host port mapping (default 5050 to avoid Synology DSM conflict on 5000)
HOST_PORT=5050

# Cloudflare Named Tunnel token (optional — only for permanent custom domain)
# Get this from: https://one.dash.cloudflare.com → Networks → Tunnels
# CLOUDFLARE_TUNNEL_TOKEN=your-token-here
